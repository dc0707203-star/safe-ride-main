<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@drawable/widget_background"
    android:padding="8dp">

    <!-- Emergency Button Container with Shadow -->
    <FrameLayout
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginBottom="8dp">

        <!-- Glow/Shadow Layer -->
        <ImageView
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_gravity="center"
            android:background="@drawable/widget_button_glow"
            android:alpha="0.6" />

        <!-- Main Button -->
        <ImageButton
            android:id="@+id/widget_sos_button"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_gravity="center"
            android:contentDescription="@string/widget_button_desc"
            android:scaleType="centerInside"
            android:padding="12dp"
            android:background="@drawable/widget_button_gradient"
            android:src="@drawable/widget_sos_icon_new"
            android:cropToPadding="true"
            android:adjustViewBounds="false" />
    </FrameLayout>

    <!-- Widget Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/widget_title"
        android:textAlignment="center"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:textStyle="bold"
        android:alpha="0.9"
        android:paddingHorizontal="4dp" />

    <!-- Widget Label/Description -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/widget_label"
        android:textAlignment="center"
        android:textColor="#FFFFFF"
        android:textSize="9sp"
        android:alpha="0.6"
        android:paddingHorizontal="4dp"
        android:paddingTop="2dp" />

</LinearLayout>
